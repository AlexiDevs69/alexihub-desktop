{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AlexiHub",
  "version": "1.0.0",
  "identifier": "com.alexihub.desktop",
  "build": {
    "devUrl": "https://basedate.onrender.com/community",
    "frontendDist": "https://basedate.onrender.com/community"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AlexiHub",
        "url": "https://basedate.onrender.com/community",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "fullscreen": false,
        "visible": true,
        "backgroundColor": "#0b0b0d"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "publisher": "AlexiHub",
    "shortDescription": "AlexiHub Desktop Messenger",
    "longDescription": "Desktop client for the AlexiHub messenger.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
